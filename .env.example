# OpenAI (vision + optional Nemotron fallback)
OPENAI_API_KEY=your_openai_api_key_here
VISION_PROVIDER=openai

# Nemotron (NVIDIA) — set NEMOTRON_PROVIDER=mock to skip
NVIDIA_API_KEY=your_nvidia_api_key_here
NEMOTRON_PROVIDER=nvidia

# Optional: override SQLite path (default: ./northern_shift_guard.db)
# DATABASE_URL=sqlite:///./northern_shift_guard.db

# Production (Docker web service — API + UI in one container): leave CORS default.
# CORS_ORIGINS=https://your-app.onrender.com

# Only if frontend and backend are separate Render services:
# VITE_API_BASE_URL=https://your-api.onrender.com

# Apify (optional — safety context already in data/safety_refs/)
APIFY_API_TOKEN=your_apify_token_here
